{
	"name": "C++",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"moby": true,
			"installDockerBuildx": true,
			"version": "latest",
			"dockerDashComposeVersion": "latest"
		}
	},
	"runArgs": [
		"--dns=1.1.1.1",
		"--dns=8.8.8.8",
		"--restart=unless-stopped"
	],
	"mounts": [
		"source=lib-ian-build,target=${containerWorkspaceFolder}/build,type=volume",
		"source=lib-ian-out,target=${containerWorkspaceFolder}/out,type=volume",
		"source=lib-ian-cache,target=${containerWorkspaceFolder}/.cache,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"llvm-vs-code-extensions.vscode-clangd"
			],
			"settings": {
				"C_Cpp.intelliSenseEngine": "disabled",
				"clangd.arguments": [
					"--background-index",
					"--clang-tidy"
				]
			}
		}
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends xdg-utils ca-certificates && [ -f .local/postcreate.sh ] && bash .local/postcreate.sh || true"
}
